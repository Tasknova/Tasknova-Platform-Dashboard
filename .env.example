# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API Configuration
VITE_API_URL=http://localhost:3000

# Feature Flags
VITE_ENABLE_DEMO_MODE=true

# ===== EMAIL CONFIGURATION (Google Cloud Service Account) =====
# For password reset emails via Google Cloud
# See EMAIL_SETUP_GUIDE.md for detailed setup instructions

# Google Cloud Project Settings
GOOGLE_PROJECT_ID=tasknova-gmail-integration
GOOGLE_SERVICE_ACCOUNT_EMAIL=gmail-syncy-service@tasknova-gmail-integration.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_ID=fe9098518289dc43669eec8bedbe43b78053e623
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=your-service-account-client-id

# Google Service Account Private Key
# IMPORTANT: Include full private key with escaped newlines
# Format: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-private-key-here\n-----END PRIVATE KEY-----\n"

# OAuth 2.0 Credentials (for token refresh)
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REDIRECT_URL=http://localhost:5173/auth/callback

# Gmail API Tokens
# Generate these using the OAuth 2.0 Playground or token generation script
GOOGLE_ACCESS_TOKEN=ya29.a0AfH6SMBx...
GOOGLE_REFRESH_TOKEN=1//0gn...

# Email Configuration
SENDER_EMAIL=tools@tasknova.io
RESET_PASSWORD_URL=http://localhost:5173/reset-password
PRODUCTION_LOGIN_URL=https://tasknova-platform-dashboard.vercel.app/login
VITE_PRODUCTION_LOGIN_URL=https://tasknova-platform-dashboard.vercel.app/login

# Backend Service URL (if using Node.js backend)
VITE_BACKEND_URL=http://localhost:3000

# ===== INDUSLABS CLICK2CALL CONFIGURATION =====
VITE_INDUSLABS_BASE_URL=https://developer.induslabs.io/api
VITE_INDUSLABS_EMAIL=your-induslabs-email@example.com
VITE_INDUSLABS_PASSWORD=your-induslabs-password
VITE_INDUSLABS_DID=919484956750
# Optional webhook callback URL for lifecycle events
VITE_INDUSLABS_CALLBACK_URL=https://your-domain.com/webhooks/induslabs/click2call

# ===== HUBSPOT CRM INTEGRATION =====
# OAuth app credentials
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-app-secret

# OAuth callback endpoint for your app flow
VITE_HUBSPOT_REDIRECT_URI=http://localhost:5173/hubspot/callback
VITE_HUBSPOT_PRODUCTION_REDIRECT_URI=https://your-domain.com/hubspot/callback

# Supabase Edge webhook endpoint configured in HubSpot App settings
HUBSPOT_WEBHOOK_URL=https://wxconkvfxcsectvbiihb.supabase.co/functions/v1/hubspot-webhook
